# Backend environment variables (reference).
# Local dev values live in the Tiltfile; real secrets should be exported in your
# shell (e.g. sourced from a gitignored .env) before running `tilt up`.

DATABASE_URL=postgres://beyond:password@localhost:5432/beyond?sslmode=disable

MINIO_ENDPOINT=localhost:9000
MINIO_USER=beyond-admin
MINIO_PASSWORD=beyond-password
MINIO_PUBLIC_URL=http://localhost:9000

SUPABASE_URL=https://<your_supabase_url>.supabase.co

# ─── Google Photos integration (optional) ────────────────────────────────
# All four must be set for the integration to activate. Leave unset to run
# without it. Get ClientID/Secret from the GCP console after enabling the
# "Photos Picker API" and configuring an OAuth 2.0 Web client. Add the
# redirect URL below to the client's allowed redirect URIs.

GOOGLE_CLIENT_ID=<your_google_oauth_client_id>
GOOGLE_CLIENT_SECRET=<your_google_oauth_client_secret>
GOOGLE_REDIRECT_URL=http://localhost:8080/api/integrations/google/callback

# 32-byte key, hex-encoded (64 hex chars). Generate with:
#   openssl rand -hex 32
GOOGLE_TOKEN_ENCRYPTION_KEY=<64_hex_chars>
